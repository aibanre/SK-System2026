<Window x:Class="SK_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Barangay SK Management System" Height="750" Width="600"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Width="480" Margin="0,40,0,40" Height="543">
            <!-- Icon -->
            <Border Width="50" Height="50" Background="#333333" CornerRadius="8" HorizontalAlignment="Center" Margin="0,0,0,20">
                <!-- Outline Shield with Checkmark Icon -->
                <Path Data="M 12 1 L 3 5 L 3 11 C 3 16.55 6.84 21.74 12 23 C 17.16 21.74 21 16.55 21 11 L 21 5 L 12 1 Z M 12 20.93 C 8.25 19.82 5 15.65 5 11 L 5 6.3 L 12 3.19 L 19 6.3 L 19 11 C 19 15.65 15.75 19.82 12 20.93 Z M 16.59 7.58 L 10 14.17 L 7.41 11.59 L 6 13 L 10 17 L 18 9 L 16.59 7.58 Z" 
                      Fill="White" Stretch="Uniform" Margin="12" />
            </Border>

            <TextBlock Text="Barangay SK Management System" FontSize="26" FontWeight="SemiBold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Sign in to access your dashboard" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Quick Access Card -->

            <!-- Login Card -->
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="30">
                <StackPanel>
                    <TextBlock Text="USERNAME" FontSize="13" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <TextBox x:Name="txtUsername" Height="42" Padding="10,0" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1" Foreground="#1F2937" VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock IsHitTestVisible="False" Text="Enter username" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" Foreground="#9CA3AF" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtUsername}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock Text="PASSWORD" FontSize="13" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <PasswordBox x:Name="pwdPassword" Height="42" Padding="10,0,40,0" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1" Foreground="#1F2937" VerticalContentAlignment="Center" PasswordChanged="PasswordBox_PasswordChanged">
                            <PasswordBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                        <TextBlock x:Name="txtPasswordPlaceholder" IsHitTestVisible="False" Text="Enter password" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" Foreground="#9CA3AF" FontSize="14"/>
                        <!-- Eye icon -->
                        <Path Data="M 12 4.5 C 7 4.5 2.73 7.61 1 12 C 2.73 16.39 7 19.5 12 19.5 C 17 19.5 21.27 16.39 23 12 C 21.27 7.61 17 4.5 12 4.5 Z M 12 17 C 9.24 17 7 14.76 7 12 C 7 9.24 9.24 7 12 7 C 14.76 7 17 9.24 17 12 C 17 14.76 14.76 17 12 17 Z M 12 9 C 10.34 9 9 10.34 9 12 C 9 13.66 10.34 15 12 15 C 13.66 15 15 13.66 15 12 C 15 10.34 13.66 9 12 9 Z" 
                              Fill="#9CA3AF" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Stretch="Uniform" Height="16" Width="20" IsHitTestVisible="False"/>
                    </Grid>

                    <CheckBox Content="Remember Me" Foreground="#6B7280" FontSize="14" Margin="0,0,0,20" VerticalContentAlignment="Center"/>

                    <Button Content="Sign In" Height="46" Background="#27272A" Foreground="White" FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
