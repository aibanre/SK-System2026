<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- SK System Window Template Styles -->

    <!-- Main Window Background -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F9FAFB"/>

    <!-- Sidebar Colors -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="RoleBadgeBackgroundBrush" Color="#002B6F"/>
    <SolidColorBrush x:Key="ActiveTabBackgroundBrush" Color="#A4BEF1"/>

    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#4B5563"/>

    <!-- Navigation Item Style -->
    <Style x:Key="NavigationItemStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F9FAFB"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Active Navigation Item Style -->
    <Style x:Key="ActiveNavigationItemStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Background" Value="{StaticResource ActiveTabBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
        <Setter Property="BorderThickness" Value="4,0,0,0"/>
    </Style>

    <!-- Topbar Style -->
    <Style x:Key="TopbarStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource SidebarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="20,15"/>
    </Style>

    <!-- Sidebar Header Style -->
    <Style x:Key="SidebarHeaderStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="20,20,20,10"/>
    </Style>

    <!-- Role Badge Style -->
    <Style x:Key="RoleBadgeStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource RoleBadgeBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Main Title Style -->
    <Style x:Key="MainTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <!-- Subtitle Style -->
    <Style x:Key="SubtitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TertiaryTextBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- User Info Style -->
    <Style x:Key="UserInfoPrimaryStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="UserInfoSecondaryStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TertiaryTextBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

</ResourceDictionary>
